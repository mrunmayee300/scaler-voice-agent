# Copy to .env and fill in values. Never commit .env to git.

# Candidate
CANDIDATE_NAME=Mrunmayee
CANDIDATE_EMAIL=you@gmail.com
CANDIDATE_TIMEZONE=Asia/Kolkata

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Qdrant Cloud (free tier at cloud.qdrant.io)
QDRANT_URL=https://your-cluster.cloud.qdrant.io
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=candidate

# Retrieval
RETRIEVAL_TOP_K=10
RERANK_TOP_K=5
CONFIDENCE_THRESHOLD=0.55

# Backend (set BACKEND_URL to your Render URL after deploy)
BACKEND_URL=http://localhost:8000
BACKEND_CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Frontend (Vercel env vars — also used locally)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_VAPI_PUBLIC_KEY=
NEXT_PUBLIC_VAPI_ASSISTANT_ID=
NEXT_PUBLIC_CANDIDATE_NAME=Mrunmayee

# Vapi
VAPI_PUBLIC_KEY=
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_WEBHOOK_SECRET=

# Email notifications (Gmail: use App Password, not regular password)
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_EMAIL=you@gmail.com

# Google Calendar
GOOGLE_CALENDAR_ID=you@gmail.com
GOOGLE_CREDENTIALS_PATH=./credentials/google-service-account.json
GOOGLE_DELEGATED_USER=
MEETING_DURATION_MINUTES=30
MEETING_BUFFER_MINUTES=15
BUSINESS_HOURS_START=8
BUSINESS_HOURS_END=20

# GitHub (for ingestion — run build_index.py locally)
GITHUB_USERNAME=
GITHUB_TOKEN=
GITHUB_REPOS=repo1,repo2
RESUME_PDF_PATH=./data/resume/resume.pdf

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/conversations.db

# Observability
LANGFUSE_ENABLED=false
ENVIRONMENT=development
LOG_LEVEL=INFO
